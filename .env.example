# === Демонстрация / учебный стенд (не для боевых паролей) ===
# Скопируйте этот файл в .env и при необходимости измените порты:
#   Windows:  copy .env.example .env
#
# Файл .env в репозиторий не коммитится (.gitignore). Для реальной БД задайте
# свои пароли и новый FERNET_KEY.

# В POSTGRES_PASSWORD и _AIRFLOW_WWW_USER_PASSWORD избегайте символов
# @ : / ? # & — иначе может сломаться строка подключения Airflow к метаданным.

# --- PostgreSQL (БД bank_ds: схемы DS и LOGS) ---
# Внутри Docker сеть: хост postgres, порт 5432. С хоста Windows: localhost и POSTGRES_PUBLISH_PORT.
POSTGRES_PORT=5432
POSTGRES_DB=bank_ds
POSTGRES_USER=postgres
POSTGRES_PASSWORD=demo_change_me
# Если порт 5432 на ПК занят — смените (и в .env тоже):
POSTGRES_PUBLISH_PORT=55433

# --- Airflow (веб-интерфейс) ---
AIRFLOW_WEB_PORT=18080
AIRFLOW_UID=50000

# Ключ шифрования для метаданных Airflow (один на весь стек). Для нового проекта сгенерируйте свой:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=3wrTBQxXEuD3HuKtG92kekRxK5zvqbBbrpDJT9uK0Mo=

# Логин в веб-интерфейс Airflow (создаётся при первом старте airflow-init)
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=demo_airflow_change_me

# Connection bank_postgres к БД ETL задаётся в docker-compose.yml (внутри сети compose: postgres:5432).

# --- Spark (задачи ETL внутри Airflow) ---
SPARK_MASTER=local[*]

# Каталог CSV на хосте → в контейнер /opt/airflow/bank_etl/CSV (путь относительно папки с docker-compose.yml).
# По умолчанию ./CSV (подпапка этого репозитория). Если Airflow поднимаете из соседней папки Project_1.1,
# задайте в .env там: HOST_CSV_DIR=../Project_1_1/CSV
